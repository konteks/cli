{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "lib": ["es2022"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "outDir": "dist",
        "paths": {
            "@/*": ["./src/*"]
        },
        "resolveJsonModule": true,
        "rootDir": ".",
        "skipLibCheck": true,
        "strict": true,
        "target": "es2022",
        "types": ["bun"],
        "verbatimModuleSyntax": true
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"]
}
