{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "lib": ["es2022"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "outDir": "dist",
        "paths": {
            "@/*": ["./src/*"]
        },
        "resolveJsonModule": true,
        "rootDir": "src",
        "skipLibCheck": true,
        "strict": true,
        "target": "es2022",
        "types": ["bun"]
    },
    "include": ["src/**/*.ts"]
}
