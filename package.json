{
    "$schema": "https://www.schemastore.org/package",
    "bin": "dist/main.js",
    "bugs": {
        "url": "https://github.com/konteks/cli/issues"
    },
    "dependencies": {
        "@huggingface/transformers": "^4.2.0",
        "@inquirer/checkbox": "^5.2.0",
        "@inquirer/confirm": "^6.1.0",
        "@inquirer/input": "^5.1.0",
        "@inquirer/number": "^4.1.0",
        "@inquirer/select": "^5.2.0",
        "@libsql/client": "^0.17.3",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@toon-format/toon": "^2.3.0",
        "@tree-sitter-grammars/tree-sitter-toml": "^0.7.0",
        "@tree-sitter-grammars/tree-sitter-yaml": "^0.7.1",
        "@vercel/detect-agent": "^1.2.3",
        "commander": "^14.0.3",
        "drizzle-orm": "^0.45.2",
        "sqlite-vec": "^0.1.9",
        "tree-sitter-json": "^0.24.8",
        "web-tree-sitter": "^0.26.9",
        "zod": "^4.4.3"
    },
    "description": "A local context graph for AI coding agents.",
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@types/bun": "^1.3.14",
        "knip": "^6.14.2",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    },
    "engines": {
        "bun": ">=1.3.0",
        "node": ">=22.13.0"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "homepage": "https://github.com/konteks/cli#readme",
    "keywords": [
        "ai-memory",
        "agent-memory",
        "coding-agent",
        "context",
        "knowledge-graph",
        "local-first",
        "mcp",
        "model-context-protocol"
    ],
    "license": "MIT",
    "name": "konteks-cli",
    "packageManager": "bun@1.3.12",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/konteks/cli.git"
    },
    "scripts": {
        "build": "tsup",
        "check": "bun --silent run build && bun --silent run lint && bun --silent run test",
        "dev": "bun src/main.ts",
        "format": "biome check --write --reporter=github",
        "lint": "bun --silent run format && knip -n --reporter compact && tsc --noEmit --pretty false",
        "prepack": "bun run build",
        "preview": "bun dist/main.js",
        "test": "bun test --reporter=dots > /dev/null 2>&1 || bun test --only-failures"
    },
    "type": "module",
    "version": "0.0.0"
}
