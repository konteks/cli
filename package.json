{
    "$schema": "https://www.schemastore.org/package",
    "bin": "bin/konteks.js",
    "bugs": {
        "url": "https://github.com/dominosaurs/konteks/issues"
    },
    "dependencies": {
        "@huggingface/transformers": "^4.2.0",
        "@inquirer/prompts": "^8.4.3",
        "@libsql/client": "^0.17.3",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
        "@toon-format/toon": "^2.2.0",
        "commander": "^14.0.3",
        "drizzle-orm": "^0.45.2",
        "tree-sitter-html": "^0.23.2",
        "tree-sitter-javascript": "^0.25.0",
        "tree-sitter-jsdoc": "^0.25.0",
        "tree-sitter-json": "^0.24.8",
        "tree-sitter-php": "^0.24.2",
        "tree-sitter-typescript": "^0.23.2",
        "web-tree-sitter": "^0.26.8",
        "zod": "^4.4.3"
    },
    "description": "A local context graph for AI coding agents.",
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@types/bun": "^1.3.13",
        "knip": "^6.12.2",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    },
    "engines": {
        "bun": ">=1.3.0",
        "node": ">=22"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "homepage": "https://github.com/dominosaurs/konteks#readme",
    "keywords": [
        "ai-memory",
        "agent-memory",
        "coding-agent",
        "context",
        "knowledge-graph",
        "local-first",
        "mcp",
        "model-context-protocol"
    ],
    "license": "MIT",
    "name": "konteks-cli",
    "packageManager": "bun@1.3.12",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dominosaurs/konteks.git"
    },
    "scripts": {
        "build": "tsup",
        "check": "bun --silent run lint && bun --silent run test && bun --silent run build",
        "dev": "bun src/main.ts",
        "format": "biome check --write --reporter=github",
        "lint": "bun --silent run format && knip -n --reporter compact && tsc --noEmit --pretty false",
        "prepack": "bun run build",
        "preview": "bun dist/main.js",
        "test": "bun test --reporter=dots > /dev/null 2>&1 || bun test --only-failures"
    },
    "type": "module",
    "version": "0.0.2"
}
