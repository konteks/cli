{
    "bin": {
        "konteks": "./dist/cli.js"
    },
    "bugs": {
        "url": "https://github.com/dominosaurs/konteks/issues"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
        "commander": "^14.0.3"
    },
    "description": "A local context graph for AI coding agents.",
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@types/bun": "^1.3.13",
        "knip": "^6.8.0",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    },
    "engines": {
        "bun": ">=1.3.0",
        "node": ">=22"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "homepage": "https://github.com/dominosaurs/konteks#readme",
    "keywords": [
        "ai-memory",
        "agent-memory",
        "coding-agent",
        "context",
        "knowledge-graph",
        "local-first",
        "mcp",
        "model-context-protocol"
    ],
    "name": "@konteks/cli",
    "packageManager": "bun@1.3.12",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dominosaurs/konteks.git"
    },
    "scripts": {
        "build": "tsup src/cli.ts --format esm --dts --clean",
        "check": "bun run lint && bun run test && bun run build",
        "dev": "bun src/cli.ts",
        "format": "biome check --write",
        "lint": "knip && biome check && tsc --noEmit",
        "prepack": "bun run build",
        "test": "bun test"
    },
    "type": "module",
    "version": "0.0.1"
}
